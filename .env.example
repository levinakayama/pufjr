# Copie este arquivo pra ".env" e preencha com os valores reais.
# NUNCA commite o ".env" de verdade — ele já está no .gitignore.

# --- GitHub ---
# Só necessário se for automatizar deploy/CI via API (ex: GitHub Actions).
# Gere em: github.com > Settings > Developer settings > Personal access tokens
GITHUB_TOKEN=

# --- Vercel ---
# Só necessário se for usar a Vercel CLI ou API pra automatizar deploys.
# Gere em: vercel.com > Account Settings > Tokens
VERCEL_TOKEN=
# ID do projeto na Vercel (aparece em Project Settings > General, depois de criar o projeto)
VERCEL_PROJECT_ID=
# ID da sua organização/time na Vercel (mesmo lugar)
VERCEL_ORG_ID=

# --- Supabase ---
# Preencher quando o projeto Supabase for criado (próximo passo).
# URL e anon key ficam em: supabase.com > seu projeto > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Chave de serviço (privilégios totais) — usar só no backend, nunca no navegador.
SUPABASE_SERVICE_ROLE_KEY=
